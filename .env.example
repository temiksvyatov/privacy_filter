PF_MODEL=openai/privacy-filter
PF_DEVICE=cpu

# Public domain served by your Caddy reverse proxy. Used by the UI for the
# info banner and added to the FastAPI CORS allow-list. Leave empty for local-only.
DOMAIN=privacy-filter.example.com

# Host port that Caddy proxies to. Match this with the upstream in your Caddyfile.
HOST_PORT=8000
